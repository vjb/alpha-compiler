# CoinMarketCap Agent Hub
CMC_API_KEY=your_coinmarketcap_api_key

# OpenAI (GPT-4o strategy compiler)
OPENAI_API_KEY=your_openai_key

# BSC Private Key (optional — for ERC-8004 identity registration + ERC-8183 escrow settlement)
BSC_PRIVATE_KEY=your_bsc_private_key

# Wallet Password (optional — defaults to random if not set)
WALLET_PASSWORD=

# x402 Autonomous Payments (optional — enables keyless CMC data access via USDC on Base)
X402_WALLET_KEY=your_base_wallet_private_key

# BNB Greenfield Storage (optional — for decentralized deliverable hosting)
GREENFIELD_PRIVATE_KEY=your_greenfield_key
GREENFIELD_BUCKET=alpha-compiler-deliverables

# IPFS/Pinata (optional — fallback storage for strategy publishing)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
