# CoinMarketCap API Key (required)
# Get one at: https://pro.coinmarketcap.com/
CMC_API_KEY=your_coinmarketcap_api_key_here

# OpenAI API Key (required for LLM compilation)
# Get one at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# BSC Private Key (optional - only needed for live execution)
# DO NOT use a mainnet wallet with real funds during development
BSC_PRIVATE_KEY=your_bsc_private_key_here

# BSC RPC URL (optional - defaults to BSC Testnet)
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
